# =============================================================================
# ClarityFlash - Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha com suas credenciais
#
# Modelos de IA utilizados:
#   - STT (Transcrição): Groq Whisper Large V3
#   - LLM (Geração de Conteúdo): Llama 3.1 8B Instruct
# =============================================================================

# -----------------------------------------------------------------------------
# =============================================================================
# ClarityFlash - Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha com suas credenciais
#
# Modelos de IA utilizados:
#   - STT (Transcrição): Groq Whisper Large V3
#   - LLM (Geração de Conteúdo): Llama 3.1 8B Instruct
# =============================================================================

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
SERVER_PORT=8081
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aulaflash?sslmode=disable
UPLOAD_DIR=/tmp/aulaflash-uploads

# -----------------------------------------------------------------------------
# Groq API (Transcrição de Áudio - STT)
# -----------------------------------------------------------------------------
# Modelo usado: whisper-large-v3
# Obtenha sua chave em: https://console.groq.com
GROQ_API_KEY=sua_chave_aqui

# Modelo de transcrição (não alterar se quiser usar o modelo padrão)
GROQ_MODEL=whisper-large-v3

# -----------------------------------------------------------------------------
# LLM - Geração de Conteúdo (Resumos e Flashcards)
# -----------------------------------------------------------------------------
# Opção 1: Hugging Face Inference API (recomendado para início rápido)
# Modelo usado: meta-llama/llama-3.1-8b-instruct
# Obtenha seu token em: https://huggingface.co/settings/tokens
HUGGING_FACE_TOKEN=seu_token_aqui

# Modelo de LLM para geração de resumos e flashcards
LLM_MODEL=meta-llama/llama-3.1-8b-instruct

# -----------------------------------------------------------------------------
# Ollama (Alternativa Local ao Hugging Face)
# -----------------------------------------------------------------------------
# Para usar Ollama local ao invés do Hugging Face:
#   1. Instale Ollama: https://ollama.ai
#   2. Pull do modelo: ollama pull llama3.1:8b
#   3. Defina USE_OLLAMA=true
USE_OLLAMA=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# -----------------------------------------------------------------------------
# Autenticação
# -----------------------------------------------------------------------------
# JWT_SECRET: Chave secreta para geração de tokens JWT (mínimo 32 caracteres)
JWT_SECRET=altere_esta_chave_para_um_valor_seguro_e_aleatorio

# API_KEY: Chave de API opcional para acesso externo (opcional)
API_KEY=
