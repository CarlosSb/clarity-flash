{
  "manifest_version": 3,
  "name": "AulaFlash - Gravar e Resumir",
  "version": "0.1.0",
  "description": "Grava audio da aba atual e gera resumo + flashcards automaticamente",
  "permissions": [
    "tabCapture",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8081/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "AulaFlash",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "48": "src/icons/icon48.png",
      "128": "src/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "icons": {
    "16": "src/icons/icon16.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/index.js"
      ]
    }
  ]
}
